# Install as /etc/edgewatch/secrets.toml with owner root:root and mode 0600.
# Never paste these values into config.toml, the Caddyfile, screenshots, or support logs.

[plex]
# A single token may be used for both servers when the same Plex account can view both.
token = "REPLACE_WITH_X_PLEX_TOKEN"

# Optional per-server overrides.  Names must exactly match [[plex_servers]] entries.
# [[plex_tokens]]
# name = "Media Node A"
# token = "REPLACE_WITH_DIFFERENT_TOKEN"

[ntfy]
# Use a difficult-to-guess topic URL or an authenticated ntfy account.
# Examples:
#   https://ntfy.sh/your-long-random-topic
#   https://ntfy.example.com/edgewatch
url = ""
token = ""

[linode]
# Use a personal access token with read-only access only.
api_token = ""
